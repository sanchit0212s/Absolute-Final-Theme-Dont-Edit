{%- comment -%}
  Product Card — 1:1 match of ProductCard.tsx
  Usage: {% render 'product-card', product: product, variant: 'grid' %}
{%- endcomment -%}

{%- liquid
  assign card_variant = variant | default: 'grid'
  assign first_variant = product.variants | first
  assign has_second_image = false
  if product.images.size > 1
    assign has_second_image = true
  endif

  assign deity_name = ''
  assign chakra_name = ''
  assign element_name = ''
  for tag in product.tags
    if tag contains 'deity:'
      assign deity_name = tag | remove: 'deity:'
    endif
    if tag contains 'chakra:'
      assign chakra_name = tag | remove: 'chakra:' | split: ' (' | first
    endif
    if tag contains 'element:'
      assign element_name = tag | remove: 'element:'
    endif
  endfor

  assign tagline = product.metafields.custom.tagline | default: product.type
-%}

{%- if card_variant == 'strip' -%}
  <a href="{{ product.url }}" class="group block" data-animate>
    <div class="card-kala">
      <div class="aspect-[3/4] overflow-hidden relative">
        {%- if product.featured_image -%}
          <img
            src="{{ product.featured_image | image_url: width: 400 }}"
            alt="{{ product.title | escape }}"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy" width="400" height="533"
          >
        {%- endif -%}
        <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
      </div>
      <div class="p-3">
        <p class="font-display text-sm text-on-surface truncate">{{ product.title }}</p>
        <p class="font-body text-xs text-accent mt-0.5">{{ first_variant.price | money }}</p>
      </div>
    </div>
  </a>

{%- else -%}
  <a href="{{ product.url }}" class="group block" data-animate
     data-product-card
     data-deity="{{ deity_name }}"
     data-chakra="{{ chakra_name }}"
     data-element="{{ element_name }}"
     data-price="{{ first_variant.price }}">
    <div style="perspective: 800px;">
      <div class="card-kala relative" data-product-tilt style="transition: transform 0.15s ease-out; transform-style: preserve-3d;">
        <div class="aspect-[3/4] overflow-hidden relative">
          {%- if product.featured_image -%}
            <img
              src="{{ product.featured_image | image_url: width: 500 }}"
              alt="{{ product.title | escape }}"
              class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105{% if has_second_image %} group-hover:opacity-0{% endif %}"
              loading="lazy" width="500" height="667"
            >
          {%- endif -%}

          {%- if has_second_image -%}
            <img
              src="{{ product.images[1] | image_url: width: 500 }}"
              alt="{{ product.title | escape }} alt"
              class="absolute inset-0 w-full h-full object-cover transition-all duration-700 opacity-0 group-hover:opacity-100 group-hover:scale-105"
              loading="lazy" width="500" height="667"
            >
          {%- endif -%}

          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

          <button
            data-quick-add="{{ first_variant.id }}"
            class="absolute bottom-3 right-3 w-9 h-9 rounded-full bg-surface/90 backdrop-blur-sm border border-border flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 hover:bg-accent hover:text-obsidian hover:border-accent"
            aria-label="Quick add {{ product.title | escape }}"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>

          {%- if deity_name != blank -%}
            <div class="absolute top-3 left-3">
              <span class="deity-chip">{{ deity_name }}</span>
            </div>
          {%- endif -%}
        </div>

        <div class="p-4">
          {%- if tagline != blank -%}
            <p class="font-body text-[10px] tracking-wider uppercase text-on-surface-faint mb-1">{{ tagline }}</p>
          {%- endif -%}
          <h3 class="font-display text-lg text-on-surface leading-tight mb-2">{{ product.title }}</h3>

          {%- if chakra_name != blank or element_name != blank -%}
            <div class="flex gap-2 mb-3">
              {%- if chakra_name != blank -%}
                <span class="font-body text-[9px] tracking-wider uppercase px-2 py-0.5 rounded-full bg-surface-3 text-on-surface-faint">{{ chakra_name }}</span>
              {%- endif -%}
              {%- if element_name != blank -%}
                <span class="font-body text-[9px] tracking-wider uppercase px-2 py-0.5 rounded-full bg-surface-3 text-on-surface-faint">{{ element_name }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}

          <div class="flex items-center justify-between">
            <span class="font-display text-xl text-accent">{{ first_variant.price | money }}</span>
            {%- if first_variant.weight > 0 -%}
              <span class="font-body text-[10px] text-on-surface-faint">{{ first_variant.weight | weight_with_unit }}</span>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </a>
{%- endif -%}
