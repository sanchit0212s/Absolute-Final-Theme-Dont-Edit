  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Fonts"
      },
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Display / Heading font",
        "default": "cormorant_garamond_n4",
        "info": "Used for headings, hero titles, and display text"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "inter_n4",
        "info": "Used for body text, navigation, and UI elements"
      },
      {
        "type": "header",
        "content": "Font sizes"
      },
      {
        "type": "range",
        "id": "font_size_base",
        "label": "Base font size (px)",
        "min": 14,
        "max": 20,
        "step": 1,
        "default": 16,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "font_size_heading_scale",
        "label": "Heading size scale",
        "min": 80,
        "max": 150,
        "step": 5,
        "default": 100,
        "unit": "%",
        "info": "Scales all heading sizes relative to the default"
      },
      {
        "type": "header",
        "content": "Prose style"
      },
      {
        "type": "checkbox",
        "id": "prose_italic",
        "label": "Use italic Cormorant Garamond for prose / descriptions",
        "default": true,
        "info": "Applies italic serif styling to product descriptions and long-form text"
      },
      {
        "type": "range",
        "id": "body_line_height",
        "label": "Body line height",
        "min": 1.4,
        "max": 2.0,
        "step": 0.1,
        "default": 1.6
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "header",
        "content": "Social accounts"
      },
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram",
        "info": "https://www.instagram.com/yourhandle"
      },
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook",
        "info": "https://www.facebook.com/yourpage"
      },
      {
        "type": "text",
        "id": "social_youtube",
        "label": "YouTube",
        "info": "https://www.youtube.com/yourchannel"
      },
      {
        "type": "text",
        "id": "social_pinterest",
        "label": "Pinterest",
        "info": "https://www.pinterest.com/yourprofile"
      },
      {
        "type": "text",
        "id": "social_twitter",
        "label": "X (Twitter)",
        "info": "https://x.com/yourhandle"
      },
      {
        "type": "text",
        "id": "social_whatsapp",
        "label": "WhatsApp number",
        "info": "Include country code, e.g. +91 98765 43210"
      }
    ]
  },
  {
    "name": "Newsletter",
    "settings": [
      {
        "type": "header",
        "content": "Newsletter popup"
      },
      {
        "type": "checkbox",
        "id": "newsletter_enable",
        "label": "Enable newsletter popup",
        "default": true
      },
      {
        "type": "text",
        "id": "newsletter_heading",
        "label": "Heading",
        "default": "Join the Divine Arts Family"
      },
      {
        "type": "textarea",
        "id": "newsletter_body",
        "label": "Body text",
        "default": "Subscribe for sacred stories, new arrivals, and exclusive offers from Haridwar."
      },
      {
        "type": "text",
        "id": "newsletter_success_message",
        "label": "Success message",
        "default": "Namaste! You have been added to our mailing list."
      },
      {
        "type": "range",
        "id": "newsletter_delay",
        "label": "Show after (seconds)",
        "min": 3,
        "max": 30,
        "step": 1,
        "default": 5,
        "unit": "s"
      },
      {
        "type": "text",
        "id": "newsletter_discount_code",
        "label": "Discount code (optional)",
        "info": "Shown after successful signup"
      }
    ]
  }
]
