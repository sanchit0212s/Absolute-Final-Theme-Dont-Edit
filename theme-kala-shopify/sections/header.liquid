<nav data-navbar class="fixed top-0 left-0 right-0 z-50 bg-surface/80 backdrop-blur-sm transition-all duration-300">
  <div class="max-w-[1400px] mx-auto px-6 flex items-center justify-between h-16">

    <!-- Logo -->
    <a href="/" class="logo-shimmer font-display text-2xl tracking-wide">{{ section.settings.logo_text }}</a>

    <!-- Desktop Navigation -->
    <div class="hidden lg:flex items-center gap-8">
      <a href="/" class="link-animated font-body text-xs tracking-[0.15em] uppercase transition-colors {% if request.path == '/' %}text-accent{% else %}text-on-surface-muted hover:text-accent{% endif %}">Home</a>
      <a href="/collections/all" class="link-animated font-body text-xs tracking-[0.15em] uppercase transition-colors {% if request.path == '/collections/all' %}text-accent{% else %}text-on-surface-muted hover:text-accent{% endif %}">Collection</a>
      <a href="/pages/guide" class="link-animated font-body text-xs tracking-[0.15em] uppercase transition-colors {% if request.path == '/pages/guide' %}text-accent{% else %}text-on-surface-muted hover:text-accent{% endif %}">Find Your Deity</a>
      <a href="/pages/about" class="link-animated font-body text-xs tracking-[0.15em] uppercase transition-colors {% if request.path == '/pages/about' %}text-accent{% else %}text-on-surface-muted hover:text-accent{% endif %}">Our Story</a>
      <a href="/pages/contact" class="link-animated font-body text-xs tracking-[0.15em] uppercase transition-colors {% if request.path == '/pages/contact' %}text-accent{% else %}text-on-surface-muted hover:text-accent{% endif %}">Contact</a>
    </div>

    <!-- Right Actions -->
    <div class="flex items-center gap-3">

      <!-- Theme Toggle (Diya Icon) -->
      <button data-theme-toggle class="w-9 h-9 rounded-full flex items-center justify-center text-on-surface-muted hover:text-accent hover:bg-accent/5 transition-all" aria-label="Toggle theme">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 15.5C4 15.5 5.5 19.5 12 19.5C18.5 19.5 20 15.5 20 15.5"/>
          <path d="M4 15.5L5 14H19L20 15.5"/>
          <path d="M7 15H17" stroke-width="1" opacity="0.4"/>
          <path data-diya-flame d="M12 12C12 12 10 9.5 10 8C10 6.5 11 5.5 12 4C13 5.5 14 6.5 14 8C14 9.5 12 12 12 12Z" fill="currentColor" stroke="currentColor" stroke-width="1.2" stroke-dasharray="0" opacity="1"/>
        </svg>
      </button>

      <!-- Cart Button -->
      <button data-cart-open class="relative w-9 h-9 rounded-full flex items-center justify-center text-on-surface-muted hover:text-accent hover:bg-accent/5 transition-all" aria-label="Open cart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span data-cart-count class="absolute -top-0.5 -right-0.5 min-w-[18px] h-[18px] bg-saffron text-white text-[9px] font-body font-bold rounded-full flex items-center justify-center hidden">0</span>
      </button>

      <!-- Mobile Menu Toggle -->
      <button data-menu-toggle class="lg:hidden w-9 h-9 rounded-full flex items-center justify-center text-on-surface-muted hover:text-accent transition-colors" aria-label="Toggle menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>

    </div>
  </div>
</nav>

<!-- Mobile Overlay -->
<div data-mobile-overlay class="fixed inset-0 bg-black/30 backdrop-blur-sm z-40 lg:hidden hidden"></div>

<!-- Mobile Menu -->
<div data-mobile-menu class="fixed top-0 right-0 bottom-0 w-72 bg-surface border-l border-border z-40 lg:hidden flex flex-col pt-24 px-6 transition-transform duration-300 translate-x-full">
  <a href="/" class="block py-3 font-body text-sm tracking-wider uppercase border-b border-border/50 transition-colors {% if request.path == '/' %}text-accent{% else %}text-on-surface-muted hover:text-accent{% endif %}">Home</a>
  <a href="/collections/all" class="block py-3 font-body text-sm tracking-wider uppercase border-b border-border/50 transition-colors {% if request.path == '/collections/all' %}text-accent{% else %}text-on-surface-muted hover:text-accent{% endif %}">Collection</a>
  <a href="/pages/guide" class="block py-3 font-body text-sm tracking-wider uppercase border-b border-border/50 transition-colors {% if request.path == '/pages/guide' %}text-accent{% else %}text-on-surface-muted hover:text-accent{% endif %}">Find Your Deity</a>
  <a href="/pages/about" class="block py-3 font-body text-sm tracking-wider uppercase border-b border-border/50 transition-colors {% if request.path == '/pages/about' %}text-accent{% else %}text-on-surface-muted hover:text-accent{% endif %}">Our Story</a>
  <a href="/pages/contact" class="block py-3 font-body text-sm tracking-wider uppercase border-b border-border/50 transition-colors {% if request.path == '/pages/contact' %}text-accent{% else %}text-on-surface-muted hover:text-accent{% endif %}">Contact</a>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "Divine Arts"
    }
  ]
}
{% endschema %}
