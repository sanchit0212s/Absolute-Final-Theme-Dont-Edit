{%- comment -%}
  About Intention — pixel-perfect match to React About.tsx "Not Decoration — Intention" section
  2-column grid: image right (order-1 lg:order-2), text left (order-2 lg:order-1)
  Feature cards in 2-column grid with card-warm p-3 styling
  No play button, no gradient overlay on image
{%- endcomment -%}

<style>
  .about-intent-fadein-left {
    opacity: 0;
    transform: translateX(-24px);
    animation: aboutIntentLeft 0.8s ease forwards;
  }
  .about-intent-fadein-right {
    opacity: 0;
    transform: translateX(24px);
    animation: aboutIntentRight 0.8s ease forwards;
  }
  @keyframes aboutIntentLeft {
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes aboutIntentRight {
    to { opacity: 1; transform: translateX(0); }
  }
</style>

<section class="py-24 section-b bg-grain">
  <div class="max-w-[1400px] mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      {%- comment -%} Text column {%- endcomment -%}
      <div class="about-intent-fadein-left order-2 lg:order-1">
        <p class="section-label mb-4">{{ section.settings.label | default: "What We Do" }}</p>

        <h2 class="font-display text-4xl text-on-surface font-light mb-6">
          {{ section.settings.heading_line1 | default: "Not Decoration —" }}<br>
          <span class="text-gradient-gold">{{ section.settings.heading_line2 | default: "Intention" }}</span>
        </h2>

        <p class="font-body text-on-surface-muted leading-relaxed mb-4">
          {{ section.settings.paragraph_1 | default: "Every piece you find here is selected with purpose in mind — to become a quiet center in your home, not just an object within it." }}
        </p>

        <p class="font-body text-on-surface-faint leading-relaxed mb-8">
          {{ section.settings.paragraph_2 | default: "Heavy, hand-cast solid brass from artisan families who have practised this craft for generations. These are not mass-produced souvenirs — they are generational anchors for your personal sanctuary." }}
        </p>

        <div class="grid grid-cols-2 gap-3">
          {%- for block in section.blocks -%}
            <div class="card-warm p-3" {{ block.shopify_attributes }}>
              <p class="font-display text-sm text-on-surface">{{ block.settings.title }}</p>
              <p class="font-body text-[10px] text-on-surface-faint">{{ block.settings.description }}</p>
            </div>
          {%- endfor -%}
        </div>
      </div>

      {%- comment -%} Image column {%- endcomment -%}
      <div class="about-intent-fadein-right order-1 lg:order-2">
        <div class="aspect-video bg-surface-2 border border-border rounded-lg overflow-hidden shadow-lg">
          {%- if section.settings.section_image != blank -%}
            <img
              src="{{ section.settings.section_image | image_url: width: 800 }}"
              alt="{{ section.settings.section_image.alt | default: 'Sacred brass forms' }}"
              loading="lazy"
              class="w-full h-full object-cover"
            >
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Intention",
  "tag": "section",
  "class": "about-intention-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "What We Do"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading line 1",
      "default": "Not Decoration —"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading line 2 (gold gradient)",
      "default": "Intention"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Paragraph 1",
      "default": "Every piece you find here is selected with purpose in mind — to become a quiet center in your home, not just an object within it."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Paragraph 2",
      "default": "Heavy, hand-cast solid brass from artisan families who have practised this craft for generations. These are not mass-produced souvenirs — they are generational anchors for your personal sanctuary."
    },
    {
      "type": "image_picker",
      "id": "section_image",
      "label": "Section image"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "100% Solid Brass"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "No hollow castings"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Intention",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "100% Solid Brass",
            "description": "No hollow castings"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Haridwar Origin",
            "description": "Artisan workshops"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Consecration Available",
            "description": "Ritual preparation on request"
          }
        }
      ]
    }
  ]
}
{% endschema %}
