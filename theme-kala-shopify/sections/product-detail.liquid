{%- comment -%}
  Product Detail -- Divine Arts theme-kala
  Pixel-perfect match of ProductDetail.tsx.
  Two-column layout: gallery (left) + product info (right).
  Gallery with zoom lightbox, arrow nav, filmstrip thumbnails.
  Info with tagline, title, mantra, description, price, specs, consecration upsell,
  diya upsell, add-to-cart, stars, tabs (vastu/chakra/element/care).
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign mantra = product.metafields.custom.mantra
  assign tagline = product.metafields.custom.tagline | default: product.type
  assign long_description = product.metafields.custom.long_description
  assign vastu_text = product.metafields.custom.vastu_placement
  assign spec_height = product.metafields.custom.height
  assign spec_size = product.metafields.custom.size_lxb
  assign spec_weight = current_variant.weight | weight_with_unit
  assign spec_finish = product.metafields.custom.finish | default: 'Antique Brass'

  comment
    Extract deity, chakra, element from tags
  endcomment
  assign tag_deity = ''
  assign tag_chakra = ''
  assign tag_element = ''
  for tag in product.tags
    if tag contains 'deity:'
      assign tag_deity = tag | remove: 'deity:'
    endif
    if tag contains 'chakra:'
      assign tag_chakra = tag | remove: 'chakra:'
    endif
    if tag contains 'element:'
      assign tag_element = tag | remove: 'element:'
    endif
  endfor

  assign display_chakra = product.metafields.custom.chakra | default: tag_chakra
  assign display_element = product.metafields.custom.element | default: tag_element

  comment
    Context-specific chakra descriptions
  endcomment
  assign chakra_name = ''
  assign chakra_desc = ''
  if tag_chakra == 'muladhara' or display_chakra contains 'Root'
    assign chakra_name = 'Root'
    assign chakra_desc = 'stability, groundedness, and security'
  elsif tag_chakra == 'svadhisthana' or display_chakra contains 'Sacral'
    assign chakra_name = 'Sacral'
    assign chakra_desc = 'fluidity, emotional intelligence, and creative flow'
  elsif tag_chakra == 'manipura' or display_chakra contains 'Solar Plexus'
    assign chakra_name = 'Solar Plexus'
    assign chakra_desc = 'will, confidence, and inner fire'
  elsif tag_chakra == 'anahata' or display_chakra contains 'Heart'
    assign chakra_name = 'Heart'
    assign chakra_desc = 'compassion, love, and emotional equilibrium'
  elsif tag_chakra == 'vishuddha' or display_chakra contains 'Throat'
    assign chakra_name = 'Throat'
    assign chakra_desc = 'expression, truth, and creative communication'
  elsif tag_chakra == 'ajna' or display_chakra contains 'Third Eye'
    assign chakra_name = 'Third Eye'
    assign chakra_desc = 'intuition, discernment, and inner vision'
  elsif tag_chakra == 'sahasrara' or display_chakra contains 'Crown'
    assign chakra_name = 'Crown'
    assign chakra_desc = 'clarity, transcendence, and spiritual connection'
  endif

  comment
    Context-specific element descriptions
  endcomment
  assign element_name = display_element
  assign element_desc = ''
  if display_element == 'Earth'
    assign element_desc = 'Earth forms provide grounding, structure, and a sense of permanence — place in areas where you need stability and rootedness.'
  elsif display_element == 'Water'
    assign element_desc = 'Water forms bring fluidity, emotional clarity, and receptivity — suited to spaces of rest, creativity, and healing.'
  elsif display_element == 'Fire'
    assign element_desc = 'Fire forms bring transformation, will, and the dissolution of stagnation — suited to spaces of action, creativity, and change.'
  elsif display_element == 'Air'
    assign element_desc = 'Air forms bring lightness, clarity, and the quality of open awareness — suited to meditation spaces and areas of study.'
  elsif display_element == 'Ether'
    assign element_desc = 'Ether forms bring spaciousness, the silence beneath all sound — the deepest presence, suited to dedicated meditation spaces.'
  endif

  comment
    Find consecration and diya addon products
  endcomment
  assign consecration_product = nil
  assign diya_product = nil

  for p in collections.all.products
    if p.handle == 'shuddhi-poojan' or p.handle contains 'consecration'
      assign consecration_product = p
    endif
    if p.handle == 'panch-mukhi-diya' or p.handle contains 'diya'
      assign diya_product = p
    endif
  endfor
-%}

{%- comment -%} Build images JSON for gallery JS {%- endcomment -%}
{%- capture images_json -%}[{%- for image in product.images -%}"{{ image | image_url: width: 1200 }}"{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]{%- endcapture -%}

{%- comment -%} Breadcrumb {%- endcomment -%}
<div class="border-b border-border bg-surface-2">
  <div class="max-w-[1400px] mx-auto px-6 py-3 flex items-center gap-3">
    <a href="/collections/all" class="flex items-center gap-1.5 font-body text-xs text-on-surface-faint hover:text-accent transition-colors">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg> Collection
    </a>
    <span class="text-border-strong">/</span>
    <span class="font-body text-xs text-on-surface-faint">{{ product.title }}</span>
  </div>
</div>

{%- comment -%} Main product area {%- endcomment -%}
<div class="max-w-[1400px] mx-auto px-6 py-12">
  <div class="grid lg:grid-cols-2 gap-14">

    {%- comment -%} ===== LEFT: Gallery ===== {%- endcomment -%}
    <div>
      {%- comment -%} Main image {%- endcomment -%}
      <div
        data-main-image
        data-images='{{ images_json }}'
        class="aspect-[3/4] bg-surface-2 border border-border rounded-lg overflow-hidden mb-3 cursor-zoom-in relative group"
      >
        <img
          id="MainImage"
          src="{{ product.featured_image | image_url: width: 900 }}"
          alt="{{ product.title | escape }}"
          class="w-full h-full object-cover transition-opacity duration-300"
        />
        <div class="absolute inset-0 flex items-center justify-center bg-black/0 group-hover:bg-black/10 transition-colors">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white opacity-0 group-hover:opacity-70 transition-opacity"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
        </div>

        {%- if product.images.size > 1 -%}
          <button
            type="button"
            data-gallery-prev
            class="absolute left-3 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-surface/80 backdrop-blur-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity hover:bg-surface"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button
            type="button"
            data-gallery-next
            class="absolute right-3 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-surface/80 backdrop-blur-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity hover:bg-surface"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        {%- endif -%}
      </div>

      {%- comment -%} Filmstrip thumbnails {%- endcomment -%}
      {%- if product.images.size > 1 -%}
        <div class="flex gap-2" id="Filmstrip">
          {%- for image in product.images -%}
            <button
              type="button"
              class="w-20 aspect-[3/4] border rounded-md overflow-hidden transition-all{% if forloop.first %} border-accent ring-1 ring-accent/30{% else %} border-border opacity-60 hover:opacity-90{% endif %}"
              data-thumb-index="{{ forloop.index0 }}"
            >
              <img
                src="{{ image | image_url: width: 200 }}"
                alt="{{ product.title | escape }} view {{ forloop.index }}"
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ===== RIGHT: Info ===== {%- endcomment -%}
    <div>
      {%- if tagline != blank -%}
        <p class="section-label mb-3">{{ tagline }}</p>
      {%- endif -%}

      <h1 class="font-display text-4xl text-on-surface font-light mb-2">{{ product.title }}</h1>

      {%- if mantra != blank -%}
        <div class="mb-4">
          <span data-mantra class="mantra-wrap">
            <span class="mantra-text text-xs">{{ mantra }}</span>
          </span>
        </div>
      {%- endif -%}

      <div class="ornament-line max-w-[200px] mb-6"></div>

      {%- if product.description != blank -%}
        <p class="font-body text-on-surface-muted leading-relaxed mb-4">{{ product.description }}</p>
      {%- endif -%}

      {%- if long_description != blank -%}
        <p class="font-body text-sm text-on-surface-faint leading-relaxed mb-8">{{ long_description }}</p>
      {%- endif -%}

      {%- comment -%} Price {%- endcomment -%}
      <div class="mb-6">
        <span class="font-display text-3xl text-accent">{{ current_variant.price | money }}</span>
      </div>

      {%- comment -%} Specs panel {%- endcomment -%}
      <div class="card-warm p-5 mb-6">
        <p class="font-body text-[10px] tracking-[0.2em] uppercase text-on-surface-faint mb-4">Specifications</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {%- if spec_height != blank -%}
            <div class="flex items-start gap-2.5">
              <div class="w-8 h-8 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M21.3 15.3a2.4 2.4 0 0 1 0 3.4l-2.6 2.6a2.4 2.4 0 0 1-3.4 0L2.7 8.7a2.41 2.41 0 0 1 0-3.4l2.6-2.6a2.41 2.41 0 0 1 3.4 0Z"/><path d="m14.5 12.5 2-2"/><path d="m11.5 9.5 2-2"/><path d="m8.5 6.5 2-2"/><path d="m17.5 15.5 2-2"/></svg>
              </div>
              <div>
                <p class="font-body text-[10px] tracking-wider uppercase text-on-surface-faint">Height</p>
                <p class="font-display text-sm text-on-surface">{{ spec_height }}</p>
              </div>
            </div>
          {%- endif -%}

          {%- if spec_size != blank -%}
            <div class="flex items-start gap-2.5">
              <div class="w-8 h-8 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
              </div>
              <div>
                <p class="font-body text-[10px] tracking-wider uppercase text-on-surface-faint">Size (L&times;B)</p>
                <p class="font-display text-sm text-on-surface">{{ spec_size }}</p>
              </div>
            </div>
          {%- endif -%}

          {%- if spec_weight != blank and current_variant.weight > 0 -%}
            <div class="flex items-start gap-2.5">
              <div class="w-8 h-8 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><circle cx="12" cy="5" r="3"/><path d="M6.5 8a2 2 0 0 0-1.905 1.46L2.1 18.23A2 2 0 0 0 4 21h16a2 2 0 0 0 1.925-2.54L19.4 9.46A2 2 0 0 0 17.48 8Z"/></svg>
              </div>
              <div>
                <p class="font-body text-[10px] tracking-wider uppercase text-on-surface-faint">Weight</p>
                <p class="font-display text-sm text-on-surface">{{ spec_weight }}</p>
              </div>
            </div>
          {%- endif -%}

          <div class="flex items-start gap-2.5">
            <div class="w-8 h-8 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><circle cx="13.5" cy="6.5" r=".5"/><circle cx="17.5" cy="10.5" r=".5"/><circle cx="8.5" cy="7.5" r=".5"/><circle cx="6.5" cy="12.5" r=".5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2Z"/></svg>
            </div>
            <div>
              <p class="font-body text-[10px] tracking-wider uppercase text-on-surface-faint">Finish</p>
              <p class="font-display text-sm text-on-surface">{{ spec_finish }}</p>
            </div>
          </div>
        </div>
        <div class="mt-4 pt-3 border-t border-border/50">
          <p class="font-body text-[10px] text-on-surface-faint">
            100% solid brass &middot; Hand-cast &middot; Dhokra lost-wax technique &middot; Haridwar origin
          </p>
        </div>
      </div>

      {%- comment -%} Add to cart {%- endcomment -%}
      <button
        type="button"
        data-add-to-cart="{{ current_variant.id }}"
        class="w-full flex items-center justify-center gap-2 py-4 rounded-md font-body text-xs tracking-[0.2em] uppercase btn-primary"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add to Altar
      </button>

      {%- comment -%} ===== CONSECRATION UPSELL CARD ===== {%- endcomment -%}
      {%- if consecration_product != nil -%}
        {%- assign cons_variant = consecration_product.variants | first -%}
        <div class="mt-4 p-5 border rounded-lg transition-colors cursor-pointer border-border bg-surface-2" data-upsell="consecration" data-variant-id="{{ cons_variant.id }}">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="font-display text-base text-on-surface mb-1">Shuddhi Poojan &mdash; Consecration Service</p>
              <p class="font-body text-xs text-on-surface-faint leading-relaxed">Prana Pratishtha performed by our resident temple pandit before your murti ships.</p>
              <p class="font-body text-xs text-accent mt-2">+{{ cons_variant.price | money }}</p>
            </div>
            <div class="flex-shrink-0 w-6 h-6 border rounded flex items-center justify-center transition-colors border-border-strong" data-upsell-check>
            </div>
          </div>
        </div>
      {%- else -%}
        {%- comment -%} Static fallback if product not found {%- endcomment -%}
        <div class="mt-4 p-5 border rounded-lg transition-colors cursor-pointer border-border bg-surface-2" data-upsell="consecration" data-variant-id="">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="font-display text-base text-on-surface mb-1">Shuddhi Poojan &mdash; Consecration Service</p>
              <p class="font-body text-xs text-on-surface-faint leading-relaxed">Prana Pratishtha performed by our resident temple pandit before your murti ships.</p>
              <p class="font-body text-xs text-accent mt-2">+&#x20B9;2,499</p>
            </div>
            <div class="flex-shrink-0 w-6 h-6 border rounded flex items-center justify-center transition-colors border-border-strong" data-upsell-check>
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} ===== DIYA UPSELL CARD ===== {%- endcomment -%}
      {%- if diya_product != nil -%}
        {%- assign diya_variant = diya_product.variants | first -%}
        <div class="mt-3 p-5 border rounded-lg transition-colors cursor-pointer border-border bg-surface-2" data-upsell="diya" data-variant-id="{{ diya_variant.id }}">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="font-display text-base text-on-surface mb-1">Traditional Brass Diya</p>
              <p class="font-body text-xs text-on-surface-faint leading-relaxed">Hand-cast five-wick diya for daily puja. Complete your altar.</p>
              <p class="font-body text-xs text-accent mt-2">+{{ diya_variant.price | money }}</p>
            </div>
            <div class="flex-shrink-0 w-6 h-6 border rounded flex items-center justify-center transition-colors border-border-strong" data-upsell-check>
            </div>
          </div>
        </div>
      {%- else -%}
        {%- comment -%} Static fallback if product not found {%- endcomment -%}
        <div class="mt-3 p-5 border rounded-lg transition-colors cursor-pointer border-border bg-surface-2" data-upsell="diya" data-variant-id="">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="font-display text-base text-on-surface mb-1">Traditional Brass Diya</p>
              <p class="font-body text-xs text-on-surface-faint leading-relaxed">Hand-cast five-wick diya for daily puja. Complete your altar.</p>
              <p class="font-body text-xs text-accent mt-2">+&#x20B9;999</p>
            </div>
            <div class="flex-shrink-0 w-6 h-6 border rounded flex items-center justify-center transition-colors border-border-strong" data-upsell-check>
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} Star rating {%- endcomment -%}
      <div class="flex items-center gap-2 mt-6">
        <div class="flex">
          {%- for i in (1..5) -%}
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1" class="text-accent">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          {%- endfor -%}
        </div>
        <span class="font-body text-xs text-on-surface-faint">4.9 &middot; 23 verified buyers</span>
      </div>

      {%- comment -%} Tabs: Vastu, Chakra, Element, Care {%- endcomment -%}
      <div class="mt-10">
        <div class="flex gap-6 border-b border-border mb-6 relative">
          <button data-tab-btn="vastu" class="tab-active">
            <span class="font-body text-xs tracking-[0.2em] uppercase">Vastu</span>
          </button>
          <button data-tab-btn="chakra" class="tab-inactive">
            <span class="font-body text-xs tracking-[0.2em] uppercase">Chakra</span>
          </button>
          <button data-tab-btn="element" class="tab-inactive">
            <span class="font-body text-xs tracking-[0.2em] uppercase">Element</span>
          </button>
          <button data-tab-btn="care" class="tab-inactive">
            <span class="font-body text-xs tracking-[0.2em] uppercase">Care</span>
          </button>
          <div data-tab-underline class="absolute bottom-0 h-[2px] bg-accent transition-all duration-300"></div>
        </div>

        {%- comment -%} Vastu tab {%- endcomment -%}
        <div data-tab-content="vastu" class="font-body text-sm text-on-surface-faint leading-relaxed">
          {{ vastu_text | default: 'Consult our Vastu guide for placement recommendations.' }}
        </div>

        {%- comment -%} Chakra tab {%- endcomment -%}
        <div data-tab-content="chakra" class="font-body text-sm text-on-surface-faint leading-relaxed hidden">
          {%- if chakra_name != blank -%}
            This form aligns with the <span class="text-accent">{{ chakra_name }}</span> chakra. Regular darshan (viewing) with intention cultivates the qualities associated with this energy centre: {{ chakra_desc }}.
          {%- else -%}
            Chakra information will be available soon.
          {%- endif -%}
        </div>

        {%- comment -%} Element tab {%- endcomment -%}
        <div data-tab-content="element" class="font-body text-sm text-on-surface-faint leading-relaxed hidden">
          {%- if element_name != blank and element_desc != blank -%}
            This murti resonates with the <span class="text-accent">{{ element_name }}</span> element. In Vedic cosmology, {{ element_desc }}
          {%- else -%}
            Element information will be available soon.
          {%- endif -%}
        </div>

        {%- comment -%} Care tab {%- endcomment -%}
        <div data-tab-content="care" class="font-body text-sm text-on-surface-faint leading-relaxed hidden">
          <p>Pure brass requires gentle care to maintain its living quality.</p>
          <ul class="mt-3 space-y-2">
            <li>&bull; Wipe with a soft dry cloth weekly</li>
            <li>&bull; For deeper cleaning, use a paste of tamarind pulp or lemon juice with salt &mdash; rinse thoroughly and dry immediately</li>
            <li>&bull; Never use abrasive cleaners or steel wool</li>
            <li>&bull; Apply a thin coat of coconut oil monthly to preserve patina</li>
            <li>&bull; Keep away from prolonged direct water exposure</li>
            <li>&bull; The natural darkening of brass over time is called Tamra-patina &mdash; it is considered auspicious, not a flaw</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

{%- comment -%} Lightbox overlay {%- endcomment -%}
<div data-lightbox class="lightbox-overlay hidden" style="z-index:100">
  <button data-lightbox-close class="absolute top-6 right-6 w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors z-10">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  {%- if product.images.size > 1 -%}
    <button data-lightbox-prev class="absolute left-6 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors z-10">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button data-lightbox-next class="absolute right-6 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors z-10">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  {%- endif -%}
  <img data-lightbox-img src="" class="max-h-[85vh] max-w-[90vw] object-contain rounded-lg shadow-2xl">
</div>

{%- comment -%} Product Detail JS {%- endcomment -%}
<script>
(function() {
  /* ===== IMAGE GALLERY ===== */
  var images = [
    {%- for image in product.images -%}
      {
        thumb: {{ image | image_url: width: 200 | json }},
        main: {{ image | image_url: width: 900 | json }},
        full: {{ image | image_url: width: 1400 | json }}
      }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];

  var activeIndex = 0;
  var lightbox = document.querySelector('[data-lightbox]');
  var lightboxImg = document.querySelector('[data-lightbox-img]');
  var mainImg = document.getElementById('MainImage');
  var mainContainer = document.querySelector('[data-main-image]');
  var filmstrip = document.getElementById('Filmstrip');

  function setActiveImage(index) {
    activeIndex = index;
    mainImg.style.opacity = '0';
    setTimeout(function() {
      mainImg.src = images[index].main;
      mainImg.style.opacity = '1';
    }, 150);

    if (lightbox && !lightbox.classList.contains('hidden')) {
      lightboxImg.src = images[index].full;
    }

    updateThumbnails();
  }

  function navigateImage(direction) {
    var newIndex = (activeIndex + direction + images.length) % images.length;
    setActiveImage(newIndex);
  }

  function updateThumbnails() {
    if (!filmstrip) return;
    var btns = filmstrip.querySelectorAll('[data-thumb-index]');
    btns.forEach(function(btn) {
      var idx = parseInt(btn.getAttribute('data-thumb-index'), 10);
      if (idx === activeIndex) {
        btn.className = 'w-20 aspect-[3/4] border rounded-md overflow-hidden transition-all border-accent ring-1 ring-accent/30';
      } else {
        btn.className = 'w-20 aspect-[3/4] border rounded-md overflow-hidden transition-all border-border opacity-60 hover:opacity-90';
      }
    });
  }

  /* Main image click -> lightbox */
  if (mainContainer) {
    mainContainer.addEventListener('click', function(e) {
      if (e.target.closest('[data-gallery-prev]') || e.target.closest('[data-gallery-next]')) return;
      openLightbox();
    });
  }

  /* Gallery nav arrows */
  var prevBtn = document.querySelector('[data-gallery-prev]');
  var nextBtn = document.querySelector('[data-gallery-next]');
  if (prevBtn) prevBtn.addEventListener('click', function(e) { e.stopPropagation(); navigateImage(-1); });
  if (nextBtn) nextBtn.addEventListener('click', function(e) { e.stopPropagation(); navigateImage(1); });

  /* Thumbnail clicks */
  if (filmstrip) {
    filmstrip.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-thumb-index]');
      if (btn) setActiveImage(parseInt(btn.getAttribute('data-thumb-index'), 10));
    });
  }

  /* ===== LIGHTBOX ===== */
  function openLightbox() {
    lightboxImg.src = images[activeIndex].full;
    lightbox.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.add('hidden');
    document.body.style.overflow = '';
  }

  var lightboxClose = document.querySelector('[data-lightbox-close]');
  if (lightboxClose) lightboxClose.addEventListener('click', closeLightbox);

  var lightboxPrev = document.querySelector('[data-lightbox-prev]');
  var lightboxNext = document.querySelector('[data-lightbox-next]');
  if (lightboxPrev) lightboxPrev.addEventListener('click', function(e) { e.stopPropagation(); navigateImage(-1); });
  if (lightboxNext) lightboxNext.addEventListener('click', function(e) { e.stopPropagation(); navigateImage(1); });

  if (lightbox) {
    lightbox.addEventListener('click', function(e) {
      if (e.target === lightbox) closeLightbox();
    });
  }

  /* Keyboard nav */
  document.addEventListener('keydown', function(e) {
    if (!lightbox || lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') navigateImage(1);
    if (e.key === 'ArrowLeft') navigateImage(-1);
  });

  /* ===== UPSELL STATE ===== */
  var upsellCards = document.querySelectorAll('[data-upsell]');
  var upsellState = {};

  upsellCards.forEach(function(card) {
    var type = card.getAttribute('data-upsell');
    upsellState[type] = false;

    card.addEventListener('click', function() {
      upsellState[type] = !upsellState[type];
      var checkbox = card.querySelector('[data-upsell-check]');

      if (upsellState[type]) {
        card.className = card.className.replace('border-border bg-surface-2', 'border-accent/40 bg-accent/5');
        checkbox.className = 'flex-shrink-0 w-6 h-6 border rounded flex items-center justify-center transition-colors bg-accent border-accent text-obsidian';
        checkbox.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
      } else {
        card.className = card.className.replace('border-accent/40 bg-accent/5', 'border-border bg-surface-2');
        checkbox.className = 'flex-shrink-0 w-6 h-6 border rounded flex items-center justify-center transition-colors border-border-strong';
        checkbox.innerHTML = '';
      }
    });
  });

  /* ===== ADD TO CART ===== */
  var addBtn = document.querySelector('[data-add-to-cart]');
  if (addBtn) {
    addBtn.addEventListener('click', function() {
      var variantId = parseInt(addBtn.getAttribute('data-add-to-cart'), 10);
      var items = [{ id: variantId, quantity: 1 }];

      /* Add selected upsells */
      upsellCards.forEach(function(card) {
        var type = card.getAttribute('data-upsell');
        var vid = card.getAttribute('data-variant-id');
        if (upsellState[type] && vid) {
          items.push({ id: parseInt(vid, 10), quantity: 1 });
        }
      });

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: items })
      })
      .then(function(res) { return res.json(); })
      .then(function() {
        addBtn.classList.remove('btn-primary');
        addBtn.classList.add('bg-surface-2', 'border', 'border-accent/50', 'text-accent');
        addBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Added to Altar';

        document.dispatchEvent(new CustomEvent('cart:updated'));
        var drawer = document.querySelector('[data-cart-drawer]');
        if (drawer) drawer.classList.add('is-open');

        setTimeout(function() {
          addBtn.classList.add('btn-primary');
          addBtn.classList.remove('bg-surface-2', 'border', 'border-accent/50', 'text-accent');
          addBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Add to Altar';
        }, 2500);
      })
      .catch(function(err) {
        console.error('Add to cart error:', err);
      });
    });
  }

  /* ===== TABS ===== */
  var tabBtns = document.querySelectorAll('[data-tab-btn]');
  var tabContents = document.querySelectorAll('[data-tab-content]');
  var tabUnderline = document.querySelector('[data-tab-underline]');

  function switchTab(tabName) {
    tabContents.forEach(function(el) { el.classList.add('hidden'); });
    var target = document.querySelector('[data-tab-content="' + tabName + '"]');
    if (target) {
      target.classList.remove('hidden');
      target.style.opacity = '0';
      target.style.transform = 'translateY(8px)';
      requestAnimationFrame(function() {
        target.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
        target.style.opacity = '1';
        target.style.transform = 'translateY(0)';
      });
    }

    tabBtns.forEach(function(btn) {
      if (btn.getAttribute('data-tab-btn') === tabName) {
        btn.className = 'tab-active';
        if (tabUnderline) {
          tabUnderline.style.left = btn.offsetLeft + 'px';
          tabUnderline.style.width = btn.offsetWidth + 'px';
        }
      } else {
        btn.className = 'tab-inactive';
      }
    });
  }

  tabBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      switchTab(btn.getAttribute('data-tab-btn'));
    });
  });

  /* Initialize underline position */
  var activeTab = document.querySelector('[data-tab-btn].tab-active') || tabBtns[0];
  if (activeTab && tabUnderline) {
    tabUnderline.style.left = activeTab.offsetLeft + 'px';
    tabUnderline.style.width = activeTab.offsetWidth + 'px';
  }
})();
</script>

<style>
  [data-tab-btn] {
    position: relative;
    padding-bottom: 0.75rem;
    cursor: pointer;
    background: none;
    border: none;
  }
  .tab-active span {
    color: var(--color-accent);
  }
  .tab-inactive span {
    color: var(--color-on-surface-muted);
  }
  .tab-inactive:hover span {
    color: var(--color-on-surface);
  }
  .lightbox-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.9);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lightbox-overlay.hidden {
    display: none;
  }
</style>

