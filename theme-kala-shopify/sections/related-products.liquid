{%- comment -%}
  Related Products -- Divine Arts theme-kala
  Matches ProductDetail.tsx lines 381-392.
  Uses Shopify product recommendations with fallback to collection products.
{%- endcomment -%}

{%- liquid
  assign limit = section.settings.limit | default: 4
  assign heading = section.settings.heading | default: 'Related Forms'
-%}

<section class="section-b border-t border-border py-16">
  <div class="max-w-[1400px] mx-auto px-6">

    {% render 'ornamental-divider', label: heading, extra_class: 'mb-10' %}

    <div id="RelatedProductsGrid" class="grid grid-cols-2 md:grid-cols-4 gap-5">
      {%- if recommendations.performed and recommendations.products_count > 0 -%}
        {%- for product in recommendations.products limit: limit -%}
          {% render 'product-card', product: product, variant: 'strip' %}
        {%- endfor -%}
      {%- elsif section.settings.collection != blank -%}
        {%- assign related_collection = collections[section.settings.collection] -%}
        {%- assign shown = 0 -%}
        {%- for rec_product in related_collection.products -%}
          {%- if rec_product.id != product.id and shown < limit -%}
            {% render 'product-card', product: rec_product, variant: 'strip' %}
            {%- assign shown = shown | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- elsif product != blank -%}
        {%- assign shown = 0 -%}
        {%- for col in product.collections -%}
          {%- for rec_product in col.products -%}
            {%- if rec_product.id != product.id and shown < limit -%}
              {% render 'product-card', product: rec_product, variant: 'strip' %}
              {%- assign shown = shown | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

{%- comment -%} Fetch Shopify product recommendations via JS and replace grid {%- endcomment -%}
{%- if product != blank -%}
<script>
(function() {
  var productId = {{ product.id | json }};
  var limit = {{ limit }};
  var grid = document.getElementById('RelatedProductsGrid');

  fetch('/recommendations/products.json?product_id=' + productId + '&limit=' + limit)
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (!data.products || data.products.length === 0) return;
      return fetch('/recommendations/products?product_id=' + productId + '&limit=' + limit + '&section_id=related-products-recommendations');
    })
    .then(function(res) {
      if (!res) return;
      return res.text();
    })
    .then(function(html) {
      if (!html) return;
      var parser = new DOMParser();
      var doc = parser.parseFromString(html, 'text/html');
      var cards = doc.querySelectorAll('.product-card-reveal, .card-kala');
      if (cards.length > 0) {
        grid.innerHTML = '';
        cards.forEach(function(card) {
          var wrapper = card.closest('a') || card;
          grid.appendChild(wrapper.cloneNode(true));
        });
        if (window.__productCardObserver) {
          grid.querySelectorAll('.product-card-reveal').forEach(function(el) {
            window.__productCardObserver.observe(el);
          });
        }
      }
    })
    .catch(function(err) {
      console.log('Using fallback related products');
    });
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Related Products",
  "tag": "div",
  "class": "related-products-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading label",
      "default": "Related Forms"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection (optional override)"
    }
  ],
  "presets": [
    {
      "name": "Related Products",
      "settings": {
        "heading": "Related Forms",
        "limit": 4
      }
    }
  ]
}
{% endschema %}
