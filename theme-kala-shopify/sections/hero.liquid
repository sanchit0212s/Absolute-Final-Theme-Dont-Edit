{%- comment -%}
  Hero — 1:1 recreation of React Index.tsx hero section.
  Two-column layout: text left, gold-framed image right.
  20 ember particles with oscillating Y. CSS-only animations.
{%- endcomment -%}

<style>
  @keyframes ember-float {
    0%   { transform: translateY(0);              opacity: 0; }
    25%  { opacity: var(--ember-peak, 0.3); }
    50%  { transform: translateY(var(--ember-y)); opacity: var(--ember-peak, 0.3); }
    75%  { opacity: var(--ember-peak, 0.3); }
    100% { transform: translateY(0);              opacity: 0; }
  }
  @keyframes hero-fade-up {
    0%   { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-fade-up-img {
    0%   { opacity: 0; transform: translateY(16px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  @keyframes dot-pulse {
    0%, 100% { opacity: 0.2; }
    50%      { opacity: 0.5; }
  }
  .kala-hero-content > * {
    opacity: 0;
    animation: hero-fade-up 0.8s ease-out both;
  }
  .kala-hero-content > *:nth-child(1) { animation-delay: 0.1s; }
  .kala-hero-content > *:nth-child(2) { animation-delay: 0.3s; }
  .kala-hero-content > *:nth-child(3) { animation-delay: 0.4s; }
  .kala-hero-content > *:nth-child(4) { animation-delay: 0.5s; }
  .kala-hero-content > *:nth-child(5) { animation-delay: 0.6s; }
  .kala-hero-content > *:nth-child(6) { animation-delay: 0.7s; }
  .kala-hero-content > *:nth-child(7) { animation-delay: 0.8s; }
  .kala-ember { position: absolute; border-radius: 50%; animation: ember-float var(--ember-dur) ease-in-out var(--ember-delay) infinite; }
  .kala-hero-frame { opacity: 0; animation: hero-fade-up 1.2s ease-out 0.4s both; }
  .kala-hero-img-wrap { opacity: 0; animation: hero-fade-up-img 0.9s ease-out 0.2s both; }
  .kala-hero-overlay { opacity: 0; animation: hero-fade-up 0.7s ease-out 0.8s both; }
  .kala-hero-dots span { animation: dot-pulse 3s ease-in-out infinite; }
  .kala-hero-dots span:nth-child(1) { animation-delay: 0s; }
  .kala-hero-dots span:nth-child(2) { animation-delay: 0.4s; }
  .kala-hero-dots span:nth-child(3) { animation-delay: 0.8s; }
  .kala-hero-dots span:nth-child(4) { animation-delay: 1.2s; }
</style>

<section class="relative overflow-hidden bg-warm-wash min-h-[90vh] flex items-center">
  {%- comment -%} Background textures {%- endcomment -%}
  <div class="absolute inset-0 bg-rangoli pointer-events-none"></div>
  <div class="absolute right-0 top-0 w-[600px] h-[600px] bg-mandala opacity-30 pointer-events-none"></div>

  {%- comment -%} 20 floating embers — oscillating Y {%- endcomment -%}
  <div class="absolute inset-0 pointer-events-none" style="z-index:2">
    {%- for i in (0..19) -%}
      {%- assign mod4 = i | modulo: 4 -%}
      {%- assign mod3 = i | modulo: 3 -%}
      {%- assign mod5 = i | modulo: 5 -%}
      {%- assign mod7 = i | modulo: 7 -%}
      {%- if mod4 == 0 -%}{%- assign esize = '8px' -%}{%- else -%}{%- assign esize = '6px' -%}{%- endif -%}
      {%- if mod3 == 0 -%}{%- assign ecolor = 'hsl(var(--shimmer-gold))' -%}{%- else -%}{%- assign ecolor = 'hsl(var(--saffron))' -%}{%- endif -%}
      {%- assign left_raw = i | times: 17 | plus: i | times: i | times: 3 | modulo: 85 | plus: 5 -%}
      {%- assign top_raw = i | times: 23 | plus: i | times: 7 | modulo: 80 | plus: 5 -%}
      {%- assign y_dist = mod5 | times: 12 | plus: 25 -%}
      {%- assign dur_raw = mod7 | times: 8 | plus: 30 -%}
      {%- assign delay_raw = i | times: 4 | modulo: dur_raw -%}
      {%- assign peak = mod4 | times: 10 | plus: 30 -%}
      <span class="kala-ember" style="
        left: {{ left_raw }}%;
        top: {{ top_raw }}%;
        width: {{ esize }};
        height: {{ esize }};
        background: {{ ecolor }};
        --ember-y: -{{ y_dist }}px;
        --ember-dur: {{ dur_raw | divided_by: 10.0 }}s;
        --ember-delay: {{ delay_raw | divided_by: 10.0 }}s;
        --ember-peak: 0.{{ peak }};
      "></span>
    {%- endfor -%}
  </div>

  <div class="max-w-[1400px] mx-auto px-6 py-20 relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      {%- comment -%} Left — Text {%- endcomment -%}
      <div class="kala-hero-content">
        <p class="section-label mb-4">{{ section.settings.label | default: 'Sacred Brass from Haridwar' }}</p>

        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl text-on-surface font-light leading-[1.1] mb-6">
          {{ section.settings.heading_line1 | default: 'Sanctuary.' }}
          <br>
          <span class="text-gradient-gold animate-gradient-shift" style="background-size: 200% 200%;">
            {{ section.settings.heading_line2 | default: 'Delivered.' }}
          </span>
        </h1>

        <div class="flex items-center gap-3 mb-6">
          <div class="w-14 h-px bg-gradient-to-r from-accent/60 to-transparent"></div>
          <div class="ornament-diamond"></div>
          <div class="w-14 h-px bg-gradient-to-l from-accent/60 to-transparent"></div>
        </div>

        <p class="font-prose text-lg text-on-surface-muted italic leading-relaxed mb-4 max-w-lg">
          {{ section.settings.subtitle_line1 | default: 'Between inner need and outer environment.' }}
          <br>
          {{ section.settings.subtitle_line2 | default: 'Between chaos and center.' }}
        </p>
        <p class="font-body text-on-surface-faint leading-relaxed mb-8 max-w-md">
          {{ section.settings.description | default: 'Hand-cast brass deity murtis from Haridwar artisan families. Each form selected with purpose — to become a quiet center in your home, not just an object within it.' }}
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
          <a href="{{ section.settings.cta1_url | default: '/collections/all' }}" class="btn-primary">
            {{ section.settings.cta1_text | default: 'Explore the Collection' }}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="{{ section.settings.cta2_url | default: '/pages/guide' }}" class="btn-outline">
            {{ section.settings.cta2_text | default: 'Find Your Deity' }}
          </a>
        </div>

        {%- comment -%} Micro-stats with CountUp {%- endcomment -%}
        <div class="flex items-center gap-8 mt-10">
          <div class="text-center">
            <p class="font-display text-2xl text-accent"><span data-count-to="13">0</span></p>
            <p class="font-body text-[10px] text-on-surface-faint tracking-wider uppercase">Sacred Forms</p>
          </div>
          <div class="w-px h-8 bg-border"></div>
          <div class="text-center">
            <p class="font-display text-2xl text-accent"><span data-count-to="40" data-count-suffix="+">0</span></p>
            <p class="font-body text-[10px] text-on-surface-faint tracking-wider uppercase">Countries</p>
          </div>
          <div class="w-px h-8 bg-border"></div>
          <div class="text-center">
            <p class="font-display text-2xl text-accent"><span data-count-to="100" data-count-suffix="%">0</span></p>
            <p class="font-body text-[10px] text-on-surface-faint tracking-wider uppercase">Solid Brass</p>
          </div>
        </div>
      </div>

      {%- comment -%} Right — Gold-framed hero image {%- endcomment -%}
      <div class="relative hidden lg:block">
        {%- comment -%} Soft golden glow behind {%- endcomment -%}
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[105%] h-[105%] rounded-full bg-accent/[0.04] blur-3xl pointer-events-none"></div>

        {%- comment -%} Gold frame border {%- endcomment -%}
        <div class="kala-hero-frame absolute -inset-3 border border-accent/25 rounded-sm pointer-events-none">
          <div class="absolute -top-1 -left-1 w-2 h-2 rounded-full bg-accent/50"></div>
          <div class="absolute -top-1 -right-1 w-1.5 h-1.5 rounded-full bg-accent/30"></div>
          <div class="absolute -bottom-1 -left-1 w-1.5 h-1.5 rounded-full bg-accent/30"></div>
          <div class="absolute -bottom-1 -right-1 w-2 h-2 rounded-full bg-accent/50"></div>
        </div>

        {%- comment -%} Main image {%- endcomment -%}
        <div class="kala-hero-img-wrap relative overflow-hidden shadow-2xl">
          <div class="aspect-[3/4]">
            {%- if section.settings.hero_image != blank -%}
              <img
                src="{{ section.settings.hero_image | image_url: width: 800 }}"
                alt="{{ section.settings.hero_image.alt | default: 'Brass deity murti in a home altar' }}"
                class="w-full h-full object-cover"
                loading="eager"
              >
            {%- else -%}
              <img
                src="https://picsum.photos/seed/brass-altar-room/600/800"
                alt="Brass Ganesh murti in a home altar"
                class="w-full h-full object-cover"
                loading="eager"
              >
            {%- endif -%}
          </div>

          {%- comment -%} Warm bottom gradient {%- endcomment -%}
          <div class="absolute inset-0 bg-gradient-to-t from-obsidian/60 via-obsidian/10 to-transparent"></div>

          {%- comment -%} Text overlay at bottom {%- endcomment -%}
          <div class="kala-hero-overlay absolute bottom-8 left-8 right-8">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-8 h-px bg-accent/60"></div>
              <p class="font-body text-[10px] tracking-[0.25em] uppercase text-white/60">From Haridwar</p>
            </div>
            <p class="font-display text-2xl text-white/90 font-light leading-snug">
              Where craft becomes
              <br>
              <span class="text-accent italic">devotion.</span>
            </p>
          </div>
        </div>

        {%- comment -%} Vertical gold dot accent — right edge {%- endcomment -%}
        <div class="kala-hero-dots absolute top-1/3 -right-7 flex flex-col gap-3 pointer-events-none" style="opacity:0; animation: hero-fade-up 1s ease-out 0.8s both;">
          <span class="w-1 h-1 rounded-full bg-accent/40"></span>
          <span class="w-1 h-1 rounded-full bg-accent/40"></span>
          <span class="w-1 h-1 rounded-full bg-accent/40"></span>
          <span class="w-1 h-1 rounded-full bg-accent/40"></span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "label", "label": "Section Label", "default": "Sacred Brass from Haridwar" },
    { "type": "text", "id": "heading_line1", "label": "Heading Line 1", "default": "Sanctuary." },
    { "type": "text", "id": "heading_line2", "label": "Heading Line 2 (gradient)", "default": "Delivered." },
    { "type": "text", "id": "subtitle_line1", "label": "Subtitle Line 1", "default": "Between inner need and outer environment." },
    { "type": "text", "id": "subtitle_line2", "label": "Subtitle Line 2", "default": "Between chaos and center." },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Hand-cast brass deity murtis from Haridwar artisan families. Each form selected with purpose — to become a quiet center in your home, not just an object within it." },
    { "type": "text", "id": "cta1_text", "label": "CTA 1 Text", "default": "Explore the Collection" },
    { "type": "url", "id": "cta1_url", "label": "CTA 1 URL" },
    { "type": "text", "id": "cta2_text", "label": "CTA 2 Text", "default": "Find Your Deity" },
    { "type": "url", "id": "cta2_url", "label": "CTA 2 URL" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero Image" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
