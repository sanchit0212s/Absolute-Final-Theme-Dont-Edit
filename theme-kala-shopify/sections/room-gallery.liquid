<section class="section-a py-20 relative">
  <div class="absolute inset-0 bg-rangoli pointer-events-none opacity-40"></div>

  <div class="max-w-[1400px] mx-auto px-6 relative">
    <!-- Section header -->
    <div class="text-center mb-14" data-animate>
      <p class="section-label mb-3">{{ section.settings.label | default: 'Designed for Your Space' }}</p>
      <h2 class="font-display text-3xl md:text-4xl text-on-surface font-light">
        {{ section.settings.heading | default: 'Where they live in your home' }}
      </h2>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-12 gap-4 auto-rows-[200px] md:auto-rows-[240px]">

      <!-- Tall left -->
      <div class="col-span-6 md:col-span-4 row-span-2 rounded-lg overflow-hidden relative group" data-animate>
        {%- if section.settings.image_1 != blank -%}
          <img
            src="{{ section.settings.image_1 | image_url: width: 800 }}"
            alt="{{ section.settings.image_1.alt | default: section.settings.room_1_name | escape }}"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
            width="{{ section.settings.image_1.width }}"
            height="{{ section.settings.image_1.height }}"
          >
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full object-cover' }}
        {%- endif -%}
        <div class="absolute inset-0 bg-gradient-to-t from-obsidian/60 via-transparent to-transparent"></div>
        <div class="absolute bottom-4 left-4 right-4">
          <p class="font-display text-base text-white mb-0.5">{{ section.settings.room_1_name | default: 'The Entryway' }}</p>
          <p class="font-body text-[10px] text-white/60 tracking-wider uppercase">{{ section.settings.room_1_desc | default: 'Ganesh · Remover of Obstacles' }}</p>
        </div>
      </div>

      <!-- Top right wide -->
      <div class="col-span-6 md:col-span-8 row-span-1 rounded-lg overflow-hidden relative group" data-animate>
        {%- if section.settings.image_2 != blank -%}
          <img
            src="{{ section.settings.image_2 | image_url: width: 1200 }}"
            alt="{{ section.settings.image_2.alt | default: section.settings.room_2_name | escape }}"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
            width="{{ section.settings.image_2.width }}"
            height="{{ section.settings.image_2.height }}"
          >
        {%- else -%}
          {{ 'collection-2' | placeholder_svg_tag: 'w-full h-full object-cover' }}
        {%- endif -%}
        <div class="absolute inset-0 bg-gradient-to-t from-obsidian/50 via-transparent to-transparent"></div>
        <div class="absolute bottom-4 left-4 right-4">
          <p class="font-display text-base text-white mb-0.5">{{ section.settings.room_2_name | default: 'The Living Room' }}</p>
          <p class="font-body text-[10px] text-white/60 tracking-wider uppercase">{{ section.settings.room_2_desc | default: 'Shiva Nataraja · Force of Transformation' }}</p>
        </div>
      </div>

      <!-- Bottom left square -->
      <div class="col-span-6 md:col-span-4 row-span-1 rounded-lg overflow-hidden relative group" data-animate>
        {%- if section.settings.image_3 != blank -%}
          <img
            src="{{ section.settings.image_3 | image_url: width: 800 }}"
            alt="{{ section.settings.image_3.alt | default: section.settings.room_3_name | escape }}"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
            width="{{ section.settings.image_3.width }}"
            height="{{ section.settings.image_3.height }}"
          >
        {%- else -%}
          {{ 'collection-3' | placeholder_svg_tag: 'w-full h-full object-cover' }}
        {%- endif -%}
        <div class="absolute inset-0 bg-gradient-to-t from-obsidian/60 via-transparent to-transparent"></div>
        <div class="absolute bottom-4 left-4 right-4">
          <p class="font-display text-base text-white mb-0.5">{{ section.settings.room_3_name | default: 'The Quiet Corner' }}</p>
          <p class="font-body text-[10px] text-white/60 tracking-wider uppercase">{{ section.settings.room_3_desc | default: 'Buddha · Embodiment of Stillness' }}</p>
        </div>
      </div>

      <!-- Bottom right square -->
      <div class="col-span-6 md:col-span-4 row-span-1 rounded-lg overflow-hidden relative group" data-animate>
        {%- if section.settings.image_4 != blank -%}
          <img
            src="{{ section.settings.image_4 | image_url: width: 800 }}"
            alt="{{ section.settings.image_4.alt | default: section.settings.room_4_name | escape }}"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
            width="{{ section.settings.image_4.width }}"
            height="{{ section.settings.image_4.height }}"
          >
        {%- else -%}
          {{ 'collection-4' | placeholder_svg_tag: 'w-full h-full object-cover' }}
        {%- endif -%}
        <div class="absolute inset-0 bg-gradient-to-t from-obsidian/60 via-transparent to-transparent"></div>
        <div class="absolute bottom-4 left-4 right-4">
          <p class="font-display text-base text-white mb-0.5">{{ section.settings.room_4_name | default: 'The Study' }}</p>
          <p class="font-body text-[10px] text-white/60 tracking-wider uppercase">{{ section.settings.room_4_desc | default: 'Saraswati · Flow of Knowledge' }}</p>
        </div>
      </div>

    </div>
  </div>
</section>

