<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" class="{% if settings.default_dark_mode %}dark{% endif %}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>
    {%- if page_title -%}{{ page_title }} &ndash; {{ shop.name }}{%- else -%}{{ shop.name }}{%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- endif -%}

  {%- comment -%} Google Fonts {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:wght@300;400;500;600&family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">

  {%- comment -%} Theme CSS (pre-compiled Tailwind) {%- endcomment -%}
  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {%- comment -%} All CSS variables (--parchment, --temple-gold, etc.) are defined
     in theme.css with correct HSL defaults. No overrides needed here.
     Font families also defined in theme.css via Tailwind config. {%- endcomment -%}

  {{ content_for_header }}
</head>

<body class="font-body text-on-surface bg-surface antialiased">

  {%- comment -%} Header {%- endcomment -%}
  {%- section 'header' -%}

  {%- comment -%} Main content — offset for fixed navbar {%- endcomment -%}
  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>

  {%- comment -%} Footer {%- endcomment -%}
  {%- section 'footer' -%}

  {%- comment -%} Cart Drawer {%- endcomment -%}
  {%- render 'cart-drawer' -%}

  {%- comment -%} Theme JS {%- endcomment -%}
  <script src="{{ 'theme.js' | asset_url }}" defer></script>

  {%- comment -%} Dark mode init — prevent flash {%- endcomment -%}
  <script>
    (function() {
      var stored = localStorage.getItem('divine-arts-theme');
      if (stored === 'dark' || (!stored && {{ settings.default_dark_mode | default: false }})) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    })();
  </script>
</body>
</html>
