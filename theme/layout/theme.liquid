<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>{{ page_title }}{% unless page_title contains shop.name %} — {{ shop.name }}{% endunless %}</title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {{ content_for_header }}

  {%- comment -%} Google Fonts – Cormorant Garamond + DM Sans {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <script>
    window.DivineArts = {
      routes: {
        cart_url: '{{ routes.cart_url }}',
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
      },
      money_format: {{ shop.money_format | json }},
      cart_count: {{ cart.item_count }},
    };
  </script>
</head>
<body class="da-body">

  {%- comment -%} Floating ember particles {%- endcomment -%}
  <div class="da-embers" aria-hidden="true">
    <span class="da-ember"></span>
    <span class="da-ember"></span>
    <span class="da-ember"></span>
    <span class="da-ember"></span>
    <span class="da-ember"></span>
    <span class="da-ember"></span>
    <span class="da-ember"></span>
    <span class="da-ember"></span>
  </div>

  {%- section 'header' -%}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  {%- comment -%} Cart Drawer {%- endcomment -%}
  {% render 'cart-drawer' %}

  {{ 'theme.js' | asset_url | script_tag }}

  {%- comment -%} Scroll-reveal observer {%- endcomment -%}
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      if ('IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('da-revealed');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

        document.querySelectorAll('.da-reveal').forEach(function(el) {
          observer.observe(el);
        });
      } else {
        document.querySelectorAll('.da-reveal').forEach(function(el) {
          el.classList.add('da-revealed');
        });
      }
    });
  </script>
</body>
</html>
