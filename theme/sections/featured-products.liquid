{%- comment -%}
  Featured Products — Grid of selected products from a collection.
{%- endcomment -%}

<section class="da-section da-bg-cream da-texture" data-section-id="{{ section.id }}">
  <div class="da-container">
    <div class="da-text-center da-reveal da-mb-4">
      <p class="da-section-label da-mb-1">{{ section.settings.label | default: "The Collection" }}</p>
      <h2 class="da-display da-display-lg da-mb-2">{{ section.settings.heading | default: "Sacred Forms" }}</h2>
      <p class="da-body-sm" style="max-width:500px;margin:0 auto;">
        {{ section.settings.description | default: "Each deity serves a purpose in your space. Not decoration — intention." }}
      </p>
    </div>

    {%- assign collection = collections[section.settings.collection] -%}
    {%- assign limit = section.settings.product_count | default: 8 -%}

    {%- if collection != blank and collection.products_count > 0 -%}
      <div class="da-grid da-grid--4">
        {%- for product in collection.products limit: limit -%}
          {%- unless product.tags contains 'addon' -%}
            {% render 'product-card', product: product, index: forloop.index0 %}
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      {%- comment -%} Fallback: show all products {%- endcomment -%}
      <div class="da-grid da-grid--4">
        {%- for product in collections.all.products limit: limit -%}
          {%- unless product.tags contains 'addon' -%}
            {% render 'product-card', product: product, index: forloop.index0 %}
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_text != blank -%}
      <div class="da-text-center da-mt-4 da-reveal">
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="da-btn da-btn--outline">
          {{ section.settings.cta_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "class": "da-featured-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "The Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sacred Forms"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Each deity serves a purpose in your space. Not decoration — intention."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Products to show",
      "min": 4,
      "max": 16,
      "step": 2,
      "default": 8
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "View Full Collection"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
