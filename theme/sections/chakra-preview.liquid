{%- comment -%}
  Chakra Alignment Preview — Visual representation of 7 chakras mapped to deities.
{%- endcomment -%}

<section class="da-section da-bg-linen da-texture" data-section-id="{{ section.id }}">
  <div class="da-container">
    <div class="da-text-center da-reveal da-mb-4">
      <p class="da-section-label da-mb-1">{{ section.settings.label | default: "Energy Alignment" }}</p>
      <h2 class="da-display da-display-md da-mb-2">{{ section.settings.heading | default: "Chakras & The Five Elements" }}</h2>
      <p class="da-body-sm" style="max-width:580px;margin:0 auto;">
        {{ section.settings.description | default: "Indian spiritual thought offers two timeless frameworks to understand balance within and around us: Chakras and Panch Tatva (The Five Elements)." }}
      </p>
    </div>

    {%- comment -%} Chakra badges strip {%- endcomment -%}
    <div class="da-chakra-strip da-reveal da-mb-4">
      {%- for block in section.blocks -%}
        {%- if block.type == 'chakra' -%}
          <div class="da-chakra-badge" {{ block.shopify_attributes }}>
            <span class="da-chakra-badge__dot da-chakra-badge__dot--{{ block.settings.key }}"></span>
            <span>{{ block.settings.name }}</span>
            {%- if block.settings.deity != blank -%}
              <span style="color:var(--da-text-light);font-size:0.6875rem;">— {{ block.settings.deity }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Two-column info: Chakras + Panch Tatva {%- endcomment -%}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;max-width:900px;margin:0 auto;">
      <div class="da-reveal da-reveal--delay-1">
        <h3 class="da-display da-display-sm da-text-copper da-mb-1">Seven Chakras</h3>
        <p class="da-body-sm">
          Chakras are described in yogic traditions as seven energy centers within the body — Root, Sacral, Solar Plexus, Heart, Throat, Third Eye, and Crown. Each represents a dimension of human experience: security, emotion, will, love, expression, insight, and awareness.
        </p>
      </div>
      <div class="da-reveal da-reveal--delay-2">
        <h3 class="da-display da-display-sm da-text-copper da-mb-1">Panch Tatva</h3>
        <p class="da-body-sm">
          Panch Tatva — the Five Elements — form the foundation of classical Hindu philosophy: Prithvi (Earth), Jal (Water), Agni (Fire), Vayu (Air), and Akash (Ether). These are seen as the building blocks of all existence, present in nature and reflected within.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .da-chakra-preview-grid { grid-template-columns: 1fr !important; }
  }
</style>

{% schema %}
{
  "name": "Chakra Preview",
  "class": "da-chakra-preview-section",
  "max_blocks": 7,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Energy Alignment"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Chakras & The Five Elements"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Indian spiritual thought offers two timeless frameworks to understand balance within and around us: Chakras and Panch Tatva (The Five Elements)."
    }
  ],
  "blocks": [
    {
      "type": "chakra",
      "name": "Chakra",
      "settings": [
        {
          "type": "text",
          "id": "key",
          "label": "CSS key (muladhara, svadhisthana, etc.)"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Display name",
          "default": "Root (Muladhara)"
        },
        {
          "type": "text",
          "id": "deity",
          "label": "Associated deity",
          "default": "Ganesh"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Chakra Preview",
      "blocks": [
        { "type": "chakra", "settings": { "key": "muladhara", "name": "Root", "deity": "Ganesh, Nandi" } },
        { "type": "chakra", "settings": { "key": "svadhisthana", "name": "Sacral", "deity": "Vishnu" } },
        { "type": "chakra", "settings": { "key": "manipura", "name": "Solar Plexus", "deity": "Ram Darbar" } },
        { "type": "chakra", "settings": { "key": "anahata", "name": "Heart", "deity": "Krishna, Hanuman" } },
        { "type": "chakra", "settings": { "key": "vishuddha", "name": "Throat", "deity": "Saraswati" } },
        { "type": "chakra", "settings": { "key": "ajna", "name": "Third Eye", "deity": "Shiva, Shivling" } },
        { "type": "chakra", "settings": { "key": "sahasrara", "name": "Crown", "deity": "Buddha, Durga, Shiv-Parvati" } }
      ]
    }
  ]
}
{% endschema %}
